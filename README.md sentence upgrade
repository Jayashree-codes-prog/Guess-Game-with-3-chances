# Guess-Game-with-3-chances
My 4th Python project - number guess Game 
import random

secret = random.randint(1, 10)
chances = 3

while chances > 0:
    guess = int(input("guess within 1  to 10: "))

    if guess == secret:
        print("Wow!you are right 🎉")
        break
    else:
        chances = chances - 1
        if chances > 0:
            print("Wrong guess! more ", chances, "chance have.")
        else:
            print("Game Over 😢")
            print("Correct number was:", secret)
